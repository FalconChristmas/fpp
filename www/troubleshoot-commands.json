{
    "CommandGroups": {
        "Networking": {
            "grpDisplayTitle": "Networking",
            "grpDescription": "Set of tools for network troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "Interfaces": {
                    "title": "Interfaces",
                    "description": "",
                    "cmd": "ifconfig -a",
                    "platforms": [
                        "all"
                    ]
                },
                "Wired": {
                    "title": "Wired",
                    "description": "",
                    "cmd": "for interface in $(ifconfig | grep -oP \"^\\w+(?=:)\" | egrep \"eth|enx\"); do echo \" \"; ethtool \"$interface\"; done;",
                    "platforms": [
                        "all"
                    ]
                },
                "Wireless": {
                    "title": "Wireless",
                    "description": "",
                    "cmd": "iw dev; cat /proc/net/wireless",
                    "platforms": [
                        "all"
                    ]
                },
                "AvailableAPs": {
                    "title": "Wifi AP Scan",
                    "description": "A scan of all available wifi network Access Points near the fpp device",
                    "cmd": "sudo bash /opt/fpp/scripts/wifi_scan.sh 2>/dev/null",
                    "platforms": [
                        "all"
                    ]
                },
                "Routing": {
                    "title": "Routing",
                    "description": "",
                    "cmd": "netstat -rn",
                    "platforms": [
                        "all"
                    ]
                },
                "DefaultGateway": {
                    "title": "Default Gateway",
                    "description": "",
                    "cmd": "for gateway in $(netstat -rn | grep \"^0.0.0.0\" | tr -s \" \" | cut -d \" \" -f 2); do ping -c 1 \"$gateway\"; done;",
                    "platforms": [
                        "all"
                    ]
                },
                "InternetAccess": {
                    "title": "Internet Access",
                    "description": "",
                    "cmd": "curl -S -s -o /dev/null -m 2 https://github.com/FalconChristmas/fpp/blob/master/README.md 2>&1 ; if [ \"$?\" -eq \"0\" ]; then echo \"GitHub reachable: **YES**\" ; else echo \"GitHub Reachable: ** NO **\"; fi;",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "Disk": {
            "grpDisplayTitle": "Disk",
            "grpDescription": "Set of tools for storage related troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "BlockDevices": {
                    "title": "Block Devices",
                    "description": "",
                    "cmd": "lsblk -l",
                    "platforms": [
                        "all"
                    ]
                },
                "Partitions": {
                    "title": "Partitions",
                    "description": "",
                    "cmd": "fdisk -l",
                    "platforms": [
                        "all"
                    ]
                },
                "Filesystems": {
                    "title": "Filesystems",
                    "description": "File System Layout and Usage",
                    "cmd": "df -h",
                    "platforms": [
                        "all"
                    ]
                },
                "MediaDirectoryUsage": {
                    "title": "Media Directory Usage",
                    "description": "Media Directory Usage ordered largest to smallest",
                    "cmd": "du -sh /home/fpp/media/*/ | sort -rh",
                    "platforms": [
                        "all"
                    ]
                },
                "Mounts": {
                    "title": "Mounts",
                    "description": "",
                    "cmd": "mount | grep -v password",
                    "platforms": [
                        "all"
                    ]
                },
                "SMART": {
                    "title": "S.M.A.R.T. Attributes",
                    "description": "",
                    "cmd": "for smartdevice in $(lsblk -nd --output NAME|grep -v zram|grep -v mmcblk); do smartctl -A /dev/$smartdevice; done;",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "DateTime": {
            "grpDisplayTitle": "Date / Time",
            "grpDescription": "Set of tools for Time and Date troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "Date": {
                    "title": "Date",
                    "description": "",
                    "cmd": "date",
                    "platforms": [
                        "all"
                    ]
                },
                "NTPPeers": {
                    "title": "NTP Peers",
                    "description": "",
                    "cmd": "pgrep ntpd > /dev/null && ntpq -c peers",
                    "platforms": [
                        "all"
                    ]
                },
                "RTC": {
                    "title": "RTC",
                    "description": "",
                    "cmd": "hwclock -v -r -f [[rtcDevice]]",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "MemoryCPU": {
            "grpDisplayTitle": "Memory / CPU",
            "grpDescription": "Set of tools for SBC troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "Memory": {
                    "title": "Memory",
                    "description": "",
                    "cmd": "free",
                    "platforms": [
                        "all"
                    ]
                },
                "Uptime": {
                    "title": "Uptime",
                    "description": "",
                    "cmd": "uptime",
                    "platforms": [
                        "all"
                    ]
                },
                "CPUUtilization": {
                    "title": "CPU Utilization",
                    "description": "",
                    "cmd": "top -bn1 | head -20",
                    "platforms": [
                        "all"
                    ]
                },
                "CPUInfo": {
                    "title": "CPUInfo",
                    "description": "",
                    "cmd": "cat /proc/cpuinfo",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "USB": {
            "grpDisplayTitle": "USB",
            "grpDescription": "Set of tools for USB troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "USBDeviceList": {
                    "title": "USB Device List",
                    "description": "",
                    "cmd": "lsusb",
                    "platforms": [
                        "all"
                    ]
                },
                "USBDeviceTree": {
                    "title": "USB Device Tree",
                    "description": "",
                    "cmd": "lsusb -t",
                    "platforms": [
                        "all"
                    ]
                },
                "USBDevices": {
                    "title": "USB Devices",
                    "description": "",
                    "cmd": "lsusb -v",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "Audio": {
            "grpDisplayTitle": "Audio",
            "grpDescription": "Set of tools for Audio troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "SoundCards": {
                    "title": "Sound Cards",
                    "description": "",
                    "cmd": "aplay -l",
                    "platforms": [
                        "all"
                    ]
                },
                "MixerDevices": {
                    "title": "Mixer Devices",
                    "description": "",
                    "cmd": "/bin/ls -1d /proc/asound/card[0-9] | sed -e \"s/.*\\/card//\" | while read ID; do echo \"CardID: ${ID}\"; sudo amixer -c ${ID} ; echo ; done",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "Media": {
            "grpDisplayTitle": "Media Backend",
            "grpDescription": "Set of tools for PipeWire and GStreamer media backend troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "PipeWireServiceStatus": {
                    "title": "PipeWire Service Status",
                    "description": "Status of the FPP PipeWire, PipeWire-Pulse, and WirePlumber systemd services",
                    "cmd": "systemctl status fpp-pipewire fpp-pipewire-pulse fpp-wireplumber --no-pager",
                    "platforms": [
                        "all"
                    ]
                },
                "PipeWireServiceLogs": {
                    "title": "PipeWire Service Logs",
                    "description": "Recent journal logs for the FPP PipeWire stack services",
                    "cmd": "journalctl -u fpp-pipewire -u fpp-wireplumber -u fpp-pipewire-pulse --no-pager | tail -50",
                    "platforms": [
                        "all"
                    ]
                },
                "WirePlumberStatus": {
                    "title": "WirePlumber Graph Status",
                    "description": "Full PipeWire graph showing all nodes, sinks, sources, and connected clients",
                    "cmd": "PIPEWIRE_RUNTIME_DIR=/run/pipewire-fpp XDG_RUNTIME_DIR=/run/pipewire-fpp wpctl status",
                    "platforms": [
                        "all"
                    ]
                },
                "PipeWireSinks": {
                    "title": "PipeWire Sinks",
                    "description": "Detailed sink information including current volume, sample format, and active port",
                    "cmd": "PIPEWIRE_RUNTIME_DIR=/run/pipewire-fpp XDG_RUNTIME_DIR=/run/pipewire-fpp PULSE_RUNTIME_PATH=/run/pipewire-fpp/pulse pactl list sinks",
                    "platforms": [
                        "all"
                    ]
                },
                "PipeWireCards": {
                    "title": "PipeWire Cards",
                    "description": "All audio hardware cards as enumerated by PipeWire and WirePlumber",
                    "cmd": "PIPEWIRE_RUNTIME_DIR=/run/pipewire-fpp XDG_RUNTIME_DIR=/run/pipewire-fpp PULSE_RUNTIME_PATH=/run/pipewire-fpp/pulse pactl list cards",
                    "platforms": [
                        "all"
                    ]
                },
                "PipeWireNodes": {
                    "title": "PipeWire Nodes",
                    "description": "Raw PipeWire node list, useful for diagnosing FX filter chain node IDs",
                    "cmd": "PIPEWIRE_RUNTIME_DIR=/run/pipewire-fpp XDG_RUNTIME_DIR=/run/pipewire-fpp timeout 3 pw-cli ls Node 2>/dev/null",
                    "platforms": [
                        "all"
                    ]
                },
                "GStreamerVersion": {
                    "title": "GStreamer Version",
                    "description": "Confirms GStreamer is installed and reports the version",
                    "cmd": "gst-inspect-1.0 --version",
                    "platforms": [
                        "all"
                    ]
                },
                "GStreamerPipeWireSink": {
                    "title": "GStreamer PipeWire Sink",
                    "description": "Verifies the pipewiresink GStreamer plugin is present and shows its properties",
                    "cmd": "gst-inspect-1.0 pipewiresink 2>&1",
                    "platforms": [
                        "all"
                    ]
                },
                "FPPMediaSettings": {
                    "title": "FPP Media Backend Settings",
                    "description": "Active FPP settings for media backend, audio output, and video output",
                    "cmd": "grep -E \"MediaBackend|ForceAudioId|AudioOutput|VideoOutput\" /home/fpp/media/settings 2>/dev/null || echo \"No media settings found\"",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "Midi": {
            "grpDisplayTitle": "Midi",
            "grpDescription": "Set of tools for Midi troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "MidiDevices": {
                    "title": "Midi Devices",
                    "description": "",
                    "cmd": "aseqdump -l",
                    "platforms": [
                        "all"
                    ]
                }
            }
        },
        "Video": {
            "grpDisplayTitle": "Video",
            "grpDescription": "Set of tools for Video troubleshooting",
            "platforms": [
                "all"
            ],
            "commands": {
                "Video": {
                    "title": "Video",
                    "description": "",
                    "cmd": "test -e /dev/fb0 && echo \"/dev/fb0\" && fbset -s -fb /dev/fb0 ; test -e /dev/fb1 && echo \"/dev/fb1\" && fbset -s -fb /dev/fb1",
                    "platforms": [
                        "all"
                    ]
                },
                "DRMConnectors": {
                    "title": "DRM Connectors",
                    "description": "DRM connector status from sysfs",
                    "cmd": "for d in /sys/class/drm/card*-*/; do echo \"=== $(basename $d) ===\"; echo \"status: $(cat $d/status 2>/dev/null)\"; echo \"enabled: $(cat $d/enabled 2>/dev/null)\"; echo \"dpms: $(cat $d/dpms 2>/dev/null)\"; modes=$(cat $d/modes 2>/dev/null); if [ -n \"$modes\" ]; then echo \"modes:\"; echo \"$modes\"; fi; echo; done",
                    "platforms": [
                        "all"
                    ]
                },
                "kmsprint": {
                    "title": "kmsprint",
                    "description": "",
                    "cmd": "kmsprint",
                    "platforms": [
                        "Raspberry Pi"
                    ]
                },
                "kmsprintProps": {
                    "title": "kmsprint -p",
                    "description": "",
                    "cmd": "kmsprint -p",
                    "platforms": [
                        "Raspberry Pi"
                    ]
                },
                "kmsprintList": {
                    "title": "kmsprint -m",
                    "description": "",
                    "cmd": "kmsprint -m",
                    "platforms": [
                        "Raspberry Pi"
                    ]
                }
            }
        },
