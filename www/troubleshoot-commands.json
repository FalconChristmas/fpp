        },
        "Git": {
            "grpDisplayTitle": "Git",
            "grpDescription": "Git source control info",
            "platforms": [
                "all"
            ],
            "commands": {
                "GitSourceIP": {
                    "title": "Git Source IP",
                    "description": "",
                    "cmd": "git remote get-url origin | cut -f3 -d/;",
