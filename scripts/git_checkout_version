#!/bin/bash

BINDIR=$(cd $(dirname $0) && pwd)

. ${BINDIR}/common
. ${BINDIR}/functions

if [ "x$1" = "x" ]
then
    echo "USAGE: $0 SHA1_HASH"
    exit
fi

teeOutput

VERS=$1

cd ${FPPDIR}/src

echo "Current Info:"

SHA1=$(git log | head -1 | awk '{print $2}')
BRANCH=$(git branch -a | grep "^\*" | awk '{print $2}' | sed -e "s/[^a-zA-Z0-9\.]*//")
if [ "x${BRANCH}" != "xHEAD" ]
then
    echo "    Branch : ${BRANCH}"
    echo "    SHA1   : ${SHA1}"
    echo "${BRANCH}" > /home/fpp/media/tmp/gitbranch
else
    BRANCH=$(cat /home/fpp/media/tmp/gitbranch)
    echo "Previous Branch: ${BRANCH}"
    echo "Current SHA1  : ${SHA1}"
fi

# clear any local changes
## FIXME before commit
#${SUDO} git reset --hard HEAD

/bin/echo -n "    Version: "
git describe --dirty

echo "======================================================================"
if [ "x${VERS}" = "xHEAD" ]
then
    echo "Attempting to switch to HEAD on ${BRANCH} branch"
else
    echo "Attempting to switch to SHA1 ${VERS} on ${BRANCH} branch"
fi

# Is this version already in our local clone
DIFF=$(git show ${VERS} 2> /dev/null)

if [ "x${DIFF}" = "x" ]
then
    # we need to fetch to find this version (a checkout of a specific SHA
    # follows, so a fetch -- not a rebasing pull -- is all that is needed here)
    echo "${VERS} not found, running 'git fetch' to sync with origin repository"
    runGitLocked "cd ${FPPDIR} && git fetch -p -P && git fetch --tags -f"
fi

DIFF=$(git show ${VERS} 2> /dev/null)

if [ "x${DIFF}" = "x" ]
then
    echo "ERROR: Unable to find git SHA1 ${VERS}"
    exit
fi

echo "======================================================================"
if [ "x${VERS}" = "xHEAD" ]
then
    echo "Checking out HEAD version"
    echo "Pulling in latest changes"
    # rebase onto the branch's upstream tracking ref rather than a bare pull
    # (see runGitLocked in scripts/functions).
    runGitLocked "cd ${FPPDIR} && git checkout ${BRANCH} && git fetch && git rebase @{u}"
else
    echo "Checking out SHA1 ${VERS}"
    ${SUDO} git checkout ${VERS}
fi

${SUDO} git branch -a | grep "^\*"
${SUDO} git log | head -10

echo "======================================================================"
echo "Rebuilding binaries"
# Embed this code here instead of using a script because we may
# revert to an older version that doesn't have that script.
# SetupBuildEnv was sourced (from functions) at the top of this script, so it
# stays defined in memory even after the checkout above swapped the files on
# disk. ${SUDO} is "sudo -E", so the exported DISTCC_HOSTS reaches make, which
# then handles ccache/distcc, NOPCH, and the triplet compiler itself.
${SUDO} make clean

SetupBuildEnv

${SUDO} make -j ${BUILD_CPUS} optimized

echo "======================================================================"
echo "Restarting fppd"

# Embed this code here instead of using a script because we may
# revert to an older version that doesn't have that script
# Clear any restart flag
sed -i -e "s/^restartFlag .*/restartFlag = \"0\"/" ${FPPHOME}/media/settings

if [ -f "/etc/fpp/container" ]
then
    /opt/fpp/scripts/fppd_stop
    /opt/fpp/scripts/fppd_start
else
    systemctl restart fppd
fi

