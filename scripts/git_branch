#!/bin/bash

BINDIR=$(cd $(dirname $0) && pwd)

. ${BINDIR}/common
. ${BINDIR}/functions

if [ "x$1" = "x" ]
then
	echo "USAGE: $0 BRANCHNAME [REMOTE]"
	exit 1
fi

# Get the remote name, default to 'origin'
REMOTE=${2:-origin}

teeOutput

# Same safe.directory hardening as git_pull -- /opt/fpp is owned by fpp:fpp,
# so root running git via sudo (which keeps HOME=/home/fpp) trips the
# "dubious ownership" guard unless /etc/gitconfig says otherwise.
$SUDO git config --system --add safe.directory /opt/fpp 2>/dev/null || true
$SUDO git config --system --add safe.directory '*' 2>/dev/null || true

echo "$0 running to switch branches to $1 from remote $REMOTE"

CNT=`cd ${FPPDIR} && git show-ref | grep "refs/remotes/$REMOTE" | grep -i $1 | wc -l`
if [ $CNT -eq 0 ]; then
	echo "Invalid Branch Name: $1 for remote: $REMOTE"
	exit 1
fi

echo "Stopping fppd"
${SUDO} ${FPPDIR}/scripts/fppd_stop

echo "Cleaning up any compiled binaries"
cleanCompiledBinaries

echo "Switching git branch to $1 from remote $REMOTE"
# Serialize the whole switch under the shared git repo lock so a background
# git_fetch can't race on FETCH_HEAD / ref locks mid-switch. rebase onto the
# tracking ref rather than a bare pull -- see runGitLocked in scripts/functions.
if [ "x${FPPDIR}" = "x/opt/fpp" ]
then
	runGitLocked "cd ${FPPDIR} && git clean -df && git reset --hard && git submodule foreach git reset --hard && git fetch $REMOTE && git checkout -B $1 $REMOTE/$1 && git rebase $REMOTE/$1 && git fetch --tags -f && git submodule sync && git submodule update --init"
else
	runGitLocked "cd ${FPPDIR} && sudo -u ${FPPUSER} git clean -df && sudo -u ${FPPUSER} git reset --hard && sudo -u ${FPPUSER} git submodule foreach git reset --hard && sudo -u ${FPPUSER} git fetch $REMOTE && sudo -u ${FPPUSER} git checkout -B $1 $REMOTE/$1 && sudo -u ${FPPUSER} git rebase $REMOTE/$1 && sudo -u ${FPPUSER} git fetch --tags -f && sudo -u ${FPPUSER} git submodule sync && sudo -u ${FPPUSER} git submodule update --init"
fi

${SUDO} ${SCRIPTDIR}/upgrade_config

echo "Compiling Binaries"
compileBinaries

# Delete any statistics
/usr/bin/curl -X DELETE http://localhost/api/statistics/usage

# If apache config file has changed copy across from branch standard
if [ -f ${FPPDIR}/etc/apache2.site ] && ! cmp -s ${FPPDIR}/etc/apache2.site /etc/apache2/sites-available/000-default.conf
then
	echo "Updating apache2 site configuration"
	${SUDO} cp ${FPPDIR}/etc/apache2.site /etc/apache2/sites-available/000-default.conf
fi


echo "Restarting fppd"
${SUDO} ${FPPDIR}/scripts/fppd_start

