#!/bin/bash




#############################################################################
# Functions for compiling and cleaning up compiled binaries
BINARIES="fppd fpp fppmm"
cleanCompiledBinaries() {
    echo "in Clean stage"

	if [ "x${FPPDIR}" = "x/opt/fpp" ]; then
		cd ${FPPDIR}/src && ${SUDO} make clean
	else
		cd ${FPPDIR}/src && sudo -u ${FPPUSER} make clean
	fi

    for p in ${MEDIADIR}/plugins/*; do
        if [ -d "$p" ]; then
            if [ -f "${p}/Makefile" ]; then
                echo "Cleaning plugin $p"
                if [ "x${FPPDIR}" = "x/opt/fpp" ]; then
                    ${SUDO} make -C "${p}" -f "${p}/Makefile" SRCDIR=${FPPDIR}/src clean
                else
                    sudo -u ${FPPUSER} make -C "${p}" -f "${p}/Makefile" SRCDIR=${FPPDIR}/src clean
                fi
            fi
        fi
    done
}
populateCCACHE() {
    FPPPLATFORM=$(cat /etc/fpp/platform 2> /dev/null)

    # Map platform (and arch, for the Pi) to the ccache asset suffix the image
    # build produces: ccache-<PLAT>.tar.gz (Pi, Pi64, BBB, BB64).
    if [ "${FPPPLATFORM}" = "Raspberry Pi" ]; then
        if [ "$(uname -m)" = "aarch64" ]; then PLAT=Pi64; else PLAT=Pi; fi
    elif [ "${FPPPLATFORM}" = "BeagleBone Black" ]; then
        PLAT=BBB
    elif [ "${FPPPLATFORM}" = "BeagleBone 64" ]; then
        PLAT=BB64
    else
        PLAT=""
        echo "populateCCACHE: unknown platform '${FPPPLATFORM}', skipping cache download"
    fi

    # The ccache tarballs are GitHub release assets attached to each release
    # tag (and to the rolling "nightly" pre-release). A custom UpgradeSource
    # mirror has no such assets, so only fetch when pulling from github.com.
    SOURCEIP=$(getSetting UpgradeSource)
    if [ -n "${PLAT}" ] && { [ "x${SOURCEIP}" = "x" ] || [ "${SOURCEIP}" = "github.com" ]; }; then
        # Most appropriate tag = the nearest release tag at/before HEAD, so
        # e.g. 10.2 plus a few commits still grabs the 10.2 cache. On master,
        # or when only a dev tag (e.g. 10.x-master) or no tag is found, fall
        # back to the rolling nightly cache -- master moves too fast for an
        # older release cache to help much.
        BRANCH=$(cd "${FPPDIR}" && sudo git rev-parse --abbrev-ref HEAD 2>/dev/null)
        TAG=$(cd "${FPPDIR}" && sudo git describe --tags --abbrev=0 2>/dev/null)
        if [ "${BRANCH}" = "master" ] || [ -z "${TAG}" ] || [ "${TAG%-master}" != "${TAG}" ]; then
            TAG="nightly"
        fi

        FILETOGET="ccache-${PLAT}.tar.gz"
        FULLURL="https://github.com/FalconChristmas/fpp/releases/download/${TAG}/${FILETOGET}"
        ETAG_GIT="/tmp/etag.$$"
        ETAG_LOCAL="/root/.cache/ccache/etag"
        NEEDS_UPDATED=0

        echo "Checking CCACHE - ${FILETOGET} - ${FULLURL}"

        sudo test -f "$ETAG_LOCAL"
        ETAG_LOCAL_NOTFOUND=$?

        # -L: release-download URLs redirect to the asset CDN; follow so we
        # read the asset's ETag, not the redirect's. Missing asset -> no etag.
        curl -sIL "$FULLURL" | grep -i '^etag:' | tail -1 > "$ETAG_GIT"
        ETAG_SIZE=$(wc -c "$ETAG_GIT" | awk '{print $1}')

        if (($ETAG_SIZE < 5)); then
            echo "Updating CCache -- no asset for ${TAG} (building without cache)"
            NEEDS_UPDATED=1
        elif [ "$ETAG_LOCAL_NOTFOUND" == "1" ]; then
            echo "Updating CCache -- not cached locally"
            NEEDS_UPDATED=1
        else
            if ! sudo diff -q "$ETAG_LOCAL" "$ETAG_GIT" >/dev/null 2>&1; then
                echo "Updating CCache -- eTag has changed"
                NEEDS_UPDATED=1
            fi
        fi

        if [ $NEEDS_UPDATED -eq 0 ]; then
            echo "CCache is up to date"
            rm -f "$ETAG_GIT"
        elif curl -f -L --fail-early "$FULLURL" --output "/tmp/$FILETOGET"; then
            sudo mkdir -p /root/.cache/ccache
            # Merge, do NOT wipe: overlay the shipped entries on top of whatever
            # is already cached locally so existing objects survive. Tarball is
            # XDG layout, so it extracts straight into the cache dir.
            sudo tar -x -z -C /root/.cache/ccache -f "/tmp/$FILETOGET"
            rm -f "/tmp/$FILETOGET"
            sudo mv "$ETAG_GIT" "$ETAG_LOCAL"
            sudo chmod 644 "$ETAG_LOCAL"
        else
            echo "CCache download failed for tag '${TAG}', building without it"
            rm -f "$ETAG_GIT"
        fi
    fi

    # Config lives at the XDG user path (/root/.config/ccache/ccache.conf),
    # not in the per-cache-dir -- ccache 4.12+ rejects several settings
    # (e.g. max_size) in the cache-dir config. Cache itself lives at
    # /root/.cache/ccache (also XDG). Clean up any stale legacy configs
    # from older installs. Match FPP_Install.sh.
    sudo rm -f /root/.ccache/ccache.conf
    sudo rm -f /root/.cache/ccache/ccache.conf
    sudo mkdir -p /root/.config/ccache
    export CCACHE_CONFIGPATH=/root/.config/ccache/ccache.conf
    sudo -E ccache -M 500M
    sudo -E ccache --set-config=temporary_dir=/tmp
    sudo -E ccache --set-config=sloppiness=pch_defines,time_macros,include_file_mtime,include_file_ctime,locale,modules
    sudo -E ccache --set-config=pch_external_checksum=true
    sudo -E ccache --set-config=hard_link=true
    # Must match FPP_Install.sh. compiler_check=content hashes the g++
    # binary bytes, which can differ between the chroot that populated the
    # shipped cache and the Pi running this upgrade -- that invalidates the
    # entire shipped cache. -dumpversion + -dumpmachine is stable across
    # binary rewrites but still changes on a real compiler upgrade.
    sudo -E ccache --set-config=compiler_check='%compiler% -dumpversion; %compiler% -dumpmachine'
}


function ComputeMakeParallelism() {
    local CPUS=1
    if [ -f "/proc/cpuinfo" ]; then
        CPUS=$(grep "^processor" /proc/cpuinfo | wc -l)

        if [[ ${CPUS} -gt 1 ]]; then
            MEMORY=$(grep MemTot /proc/meminfo | awk '{print $2}')
            ARMV=$(uname -m)

            # MemTotal includes the CMA pool, but on the Pi the vc4-KMS driver
            # reserves a large CMA region (512MB by default on a Pi4). Those
            # pages are dedicated to DMA/GPU buffers and migration out of CMA
            # fails under pressure, so for the purpose of sizing the compile we
            # treat CMA as unavailable. Without this, a 1GB Pi4 reports ~730MB
            # MemTotal, lands in the -j3 bucket, and the OOM-killer kills cc1plus
            # mid-build (see issue #2679). CmaTotal is absent on non-CMA kernels.
            CMATOTAL=$(grep "^CmaTotal" /proc/meminfo | awk '{print $2}')
            if [[ -n "${CMATOTAL}" && ${CMATOTAL} -gt 0 && ${MEMORY} -gt ${CMATOTAL} ]]; then
                MEMORY=$((MEMORY - CMATOTAL))
            fi
            if [[ ${MEMORY} -lt 425000 ]]; then
                # very limited memory, only use one core or we'll fail or
                # will be very slow as we constantly swap in/out
                CPUS=1
            elif [[ ${MEMORY} -lt 512000 ]]; then
                if [ "$ARMV" = "aarch64" ]; then
                    # 64bit compiles take more memory so if we are less than 512M, 
                    # we need to stick with a single core or it will swap
                    CPUS=1
                else
                    SWAPTOTAL=$(grep SwapTotal /proc/meminfo | awk '{print $2}')
                    # Limited memory, if we have some swap, we'll go ahead with -j 2
                    # otherwise we'll need to stick with -j 1 or we run out of memory
                    if [[ ${SWAPTOTAL} -gt 49000 ]]; then
                        CPUS=2
                    else
                        CPUS=1
                    fi
                fi
            elif [[ ${MEMORY} -lt 1000000 ]]; then
                if [[ ${CPUS} -gt 3 ]]; then
                    CPUS=3
                fi
            fi
        fi
    else
        CPUS=$(sysctl -n hw.ncpu)
    fi
    echo "$CPUS"
}

# Recommended make -j for a distcc build. The heavy compiles run on the helper,
# so we feed roughly the sum of the helper job slots (the "/N" in DISTCC_HOSTS)
# plus a little local headroom for preprocessing and the final link. With an
# mDNS/zeroconf host list the slot count is unknown, so fall back to a default.
function ComputeDistccParallelism() {
    local hosts="$1" total=0 tok n
    if [ -z "${hosts}" ] || echo "${hosts}" | grep -qi "zeroconf"; then
        echo 8
        return
    fi
    for tok in ${hosts}; do
        n=$(echo "${tok}" | sed -n 's@^[^/]*/\([0-9][0-9]*\).*@\1@p')
        if [ -n "${n}" ]; then
            total=$((total + n))
        else
            total=$((total + 4))
        fi
    done
    total=$((total + 2))
    [ "${total}" -lt 2 ] && total=2
    [ "${total}" -gt 24 ] && total=24
    echo "${total}"
}

# Discover distcc helpers advertised on the LAN via mDNS and emit a DISTCC_HOSTS
# list ("addr:port/jobs,lzo ..."). We browse _distcc._tcp with avahi ourselves
# instead of using distcc's built-in "+zeroconf" because distcc's zeroconf
# discovery filters helpers by CPU architecture and silently drops a cross-arch
# helper (an aarch64 Pi advertises "aarch64", so an armhf BeagleBone ignores it).
# Feeding the discovered helpers as EXPLICIT hosts skips that filter; helpers set
# up via setup_distcc_host.sh carry both the native and the armhf cross
# toolchains, so any of them can serve any client. Empty if avahi or no helper
# is found.
function DiscoverDistccHosts() {
    command -v avahi-browse >/dev/null 2>&1 || return 0
    local out="" marker iface proto name typ domain host addr port rest jobs
    while IFS=';' read -r marker iface proto name typ domain host addr port rest; do
        [ "${marker}" = "=" ] && [ "${proto}" = "IPv4" ] || continue
        [ -n "${addr}" ] && [ -n "${port}" ] || continue
        jobs=$(echo "${rest}" | grep -oE 'jobs=[0-9]+' | head -1 | cut -d= -f2)
        [ -n "${jobs}" ] || jobs=4
        out="${out} ${addr}:${port}/${jobs},lzo"
    done < <(timeout 4 avahi-browse -rp _distcc._tcp 2>/dev/null)
    echo "${out# }"
}

# Prepare the environment for a source rebuild based on the FPP distcc settings.
# MUST be called directly (not in a $(...) subshell) so the DISTCC_HOSTS export
# survives into the make that follows. Sets these globals:
#   DISTCC_HOSTS   exported (or unset). When set, src/makefiles automatically
#                  switch to "ccache distcc", disable the PCH, and select the
#                  target-triplet compiler so the helper cross-compiles -- no
#                  CXXCOMPILER override needed here.
#   BUILD_CPUS     the -j value to pass to make
function SetupBuildEnv() {
    local enabled hosts
    hosts=""
    enabled=$(getSetting DistccEnabled)
    if [ "${enabled}" = "1" ]; then
        if [ "$(getSetting DistccUseMDNS)" = "1" ]; then
            # Browse the LAN for advertised helpers ourselves (works cross-arch,
            # unlike distcc's "+zeroconf" -- see DiscoverDistccHosts).
            hosts=$(DiscoverDistccHosts)
            [ -z "${hosts}" ] && echo "distcc: mDNS enabled but no helpers were discovered on the network"
        else
            hosts=$(getSetting DistccHosts)
        fi
    fi

    if [ -n "${hosts}" ]; then
        export DISTCC_HOSTS="${hosts}"
        # DISTCC_DIR (distcc's lock/state dir) is pinned by src/makefiles, not
        # here: it defaults to $HOME/.distcc, but HOME is unreliable across the
        # PHP -> sudo build chain (it can be /home/fpp -- root-owned and NOT
        # writable by the apache "fpp" user -- /root, or unset). The makefile
        # sets a fixed, HOME-independent DISTCC_DIR keyed to the uid that runs
        # the compiler, which is the only place that uid is known.
        BUILD_CPUS=$(ComputeDistccParallelism "${hosts}")
        echo "Building with distcc: DISTCC_HOSTS='${DISTCC_HOSTS}', -j ${BUILD_CPUS} (PCH disabled; makefile selects the triplet compiler)"
    else
        unset DISTCC_HOSTS
        BUILD_CPUS=$(ComputeMakeParallelism)
    fi
}

compileBinaries() {

    cleanCompiledBinaries
    if [ "${FPPPLATFORM}" != "MacOS" ]; then
        populateCCACHE
    fi

    # export CCACHE_LOGFILE=/tmp/cache.debug
    export LANG=en_US.UTF-8
    export TERM=linux

    # Honor the distcc developer settings: SetupBuildEnv exports DISTCC_HOSTS
    # (which ${SUDO} == "sudo -E" then passes to make) and sizes -j; the
    # makefiles switch to ccache distcc + NOPCH + the triplet compiler. No-op
    # when distcc is disabled (BUILD_CPUS == ComputeMakeParallelism).
    SetupBuildEnv
    CPUS=${BUILD_CPUS}

    # Need to unset HOME so that ccache will user /root instead of /home/fpp
    unset HOME

    if [ "${FPPPLATFORM}" != "MacOS" ]; then
        MEMORY=$(grep MemTot /proc/meminfo | awk '{print $2}')
        FPPDPID=$(pgrep fppd)
        if [ ${MEMORY} -lt 512000 -a "${FPPDPID}" != "" ]; then
            SWAPTOTAL=$(grep SwapTotal /proc/meminfo | awk '{print $2}')
            
            if [ ${SWAPTOTAL} -lt 384000 ]; then
                echo "System has less than 512MB RAM and little swap, activating more swap."
                # Create swapfile in fpp media so it will go onto the
                # storage location most likely having space on it (not
                # eMMC on Beagles)
                #
                # some of the larger C++ files are consuming a lot of memory
                # and are starting to cause compile failures on the devices
                # with limitted memory (PiZeros, older Pi's, etc...) so
                # we'll allocate a swap file so it shouldn't fail, but
                # will likely be slow.   We DON'T want an "always" swapfile
                # to avoid killing the SD cards.
                ${SUDO} fallocate -l 384M "${FPPHOME}/media/tmp/swapfile"
                ${SUDO} chmod 600 "${FPPHOME}/media/tmp/swapfile"
                ${SUDO} mkswap -q "${FPPHOME}/media/tmp/swapfile"
                ${SUDO} swapon "${FPPHOME}/media/tmp/swapfile"
            fi
        fi
    fi

	if [ "x${FPPDIR}" = "x/opt/fpp" ]; then
		cd ${FPPDIR}/src && ${SUDO} make clean && ${SUDO} -E make -j ${CPUS} optimized
	else
		cd ${FPPDIR}/src && sudo -u ${FPPUSER} make clean && sudo -u ${FPPUSER} make -j ${CPUS} optimized
	fi

    for p in ${MEDIADIR}/plugins/*; do
        if [ -d "$p" ]; then
            if [ -f "${p}/Makefile" ]; then
                echo "Building plugin $p"
                if [ "x${FPPDIR}" = "x/opt/fpp" ]; then
                    ${SUDO} make -C "${p}" -f "${p}/Makefile" -j ${CPUS} SRCDIR=${FPPDIR}/src
                    ${SUDO} chown -R ${FPPUSER}:${FPPGROUP} "${p}"
                else
                    sudo -u ${FPPUSER} make -C "${p}" -f "${p}/Makefile" -j ${CPUS} SRCDIR=${FPPDIR}/src
                fi
            fi
        fi
    done

    if [ "${FPPPLATFORM}" != "MacOS" ]; then    
        if [ -f "${FPPHOME}/media/tmp/swapfile" ]; then
            #remove the swap that was created
            ${SUDO} swapoff "${FPPHOME}/media/tmp/swapfile"
            ${SUDO} rm -f "${FPPHOME}/media/tmp/swapfile"
        fi
    fi
}

#############################################################################
# Helper script for running the User hook script with a specified hook
runUserHookScript() {
	if [ -f "${MEDIADIR}/scripts/UserCallbackHook.sh" ]
	then
		/bin/bash ${MEDIADIR}/scripts/UserCallbackHook.sh $1
	fi
}
# These are normally run from fppd_start and fppd_stop
runPreStartScripts() {
	runUserHookScript preStart

	/bin/ls -1 ${PLUGINDIR}/*/scripts/preStart.sh 2> /dev/null | while read FILE
	do
		echo "Running: ${FILE}"
		/bin/bash ${FILE}
	done
}

runPostStartScripts() {
	/bin/ls -1 ${PLUGINDIR}/*/scripts/postStart.sh 2> /dev/null | while read FILE
	do
		echo "Running: ${FILE}"
		/bin/bash ${FILE}
	done

	runUserHookScript postStart
}

runPreStopScripts() {
	runUserHookScript preStop

	/bin/ls -1 ${PLUGINDIR}/*/scripts/preStop.sh 2> /dev/null | while read FILE
	do
		echo "Running: ${FILE}"
		/bin/bash ${FILE}
	done
}

runPostStopScripts() {
	/bin/ls -1 ${PLUGINDIR}/*/scripts/postStop.sh 2> /dev/null | while read FILE
	do
		echo "Running: ${FILE}"
		/bin/bash ${FILE}
	done

	runUserHookScript postStop
}


#############################################################################
# Handle calling a function directly
#
# Example: /opt/fpp/scripts/functions runPreStartScripts
BASENAME=$(basename -- $0)
if [ "${BASENAME}" = "functions" -a -n "$1" ]
then
    $@
fi

